# Auto detect text files and perform LF normalization
# 自动检测文本文件并执行LF规范化
* text=auto

# Source code files - force LF (Unix style)
# 源代码文件 - 强制使用LF（Unix风格）
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.rs text eol=lf
*.go text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.mts text eol=lf
*.cts text eol=lf

# Windows specific files - force CRLF
# Windows特定文件 - 强制使用CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Documentation files
# 文档文件
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Config files
# 配置文件
*.cfg text eol=lf
*.conf text eol=lf
*.ini text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Web files
# Web文件
*.html text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.sass text eol=lf
*.less text eol=lf
*.svg text eol=lf
*.xml text eol=lf

# Binary files - don't touch
# 二进制文件 - 不处理
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp3 binary
*.mp4 binary
*.wav binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
