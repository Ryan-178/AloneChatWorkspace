{
  "folders": [
    {
      "name": "chat-app-backend",
      "path": "chat-app/backend"
    },
    {
      "name": "chat-app-frontend",
      "path": "chat-app/frontend"
    },
    {
      "name": "agent-framework",
      "path": "agent-framework"
    }
  ],
  "settings": {
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.formatOnType": true,
    "editor.rulers": [88, 120],
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.exclude": {
      "**/__pycache__": true,
      "**/.pytest_cache": true,
      "**/.ruff_cache": true,
      "**/.next": true,
      "**/node_modules": true,
      "**/dist": true,
      "**/.venv": true,
      "**/venv": true
    },
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,
    "python.analysis.completeFunctionParens": true,
    "python.analysis.inlayHints.functionReturnTypes": true,
    "python.analysis.inlayHints.variableTypes": true,
    "python.formatting.provider": "none",
    "python.linting.enabled": true,
    "python.linting.lintOnSave": true,
    "ruff.organizeImports": true,
    "ruff.fixAll": true,
    "typescript.tsdk": "chat-app/frontend/node_modules/typescript/lib",
    "typescript.enablePromptUseWorkspaceTsdk": true,
    "eslint.workingDirectories": [
      "chat-app/frontend"
    ],
    "[python]": {
      "editor.defaultFormatter": "charliermarsh.ruff",
      "editor.codeActionsOnSave": {
        "source.fixAll": "explicit",
        "source.organizeImports": "explicit"
      }
    },
    "[javascript]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescript]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[markdown]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[yaml]": {
      "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[toml]": {
      "editor.defaultFormatter": "tamasfe.even-better-toml"
    }
  },
  "launch": {
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Backend Dev Server",
        "type": "debugpy",
        "request": "launch",
        "module": "uvicorn",
        "args": [
          "main:app",
          "--reload",
          "--host",
          "0.0.0.0",
          "--port",
          "8000"
        ],
        "cwd": "${workspaceFolder:chat-app-backend}",
        "jinja": false,
        "env": {
          "PYTHONPATH": "${workspaceFolder:chat-app-backend}"
        },
        "console": "integratedTerminal"
      },
      {
        "name": "Frontend Dev Server",
        "type": "node",
        "request": "launch",
        "runtimeExecutable": "npm",
        "runtimeArgs": ["run", "dev"],
        "cwd": "${workspaceFolder:chat-app-frontend}",
        "console": "integratedTerminal",
        "internalConsoleOptions": "neverOpen"
      },
      {
        "name": "Python Tests",
        "type": "debugpy",
        "request": "launch",
        "module": "pytest",
        "args": [
          "-v",
          "--tb=short"
        ],
        "cwd": "${workspaceFolder:agent-framework}",
        "env": {
          "PYTHONPATH": "${workspaceFolder:agent-framework}"
        },
        "console": "integratedTerminal"
      },
      {
        "name": "Attach to Backend",
        "type": "debugpy",
        "request": "attach",
        "connect": {
          "host": "localhost",
          "port": 5678
        },
        "pathMappings": [
          {
            "localRoot": "${workspaceFolder:chat-app-backend}",
            "remoteRoot": "."
          }
        ],
        "justMyCode": false
      },
      {
        "name": "Agent Framework Tests",
        "type": "debugpy",
        "request": "launch",
        "module": "pytest",
        "args": [
          "-v",
          "--tb=short"
        ],
        "cwd": "${workspaceFolder:agent-framework}",
        "env": {
          "PYTHONPATH": "${workspaceFolder:agent-framework}"
        },
        "console": "integratedTerminal"
      }
    ],
    "compounds": [
      {
        "name": "Full Stack Dev",
        "configurations": ["Backend Dev Server", "Frontend Dev Server"],
        "stopAll": true
      }
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "Install All Dependencies",
        "detail": "Install Python and Node.js dependencies for all sub-projects",
        "type": "shell",
        "command": "make",
        "args": ["install"],
        "options": {
          "cwd": "${workspaceFolder}"
        },
        "group": "build",
        "presentation": {
          "echo": true,
          "reveal": "always",
          "focus": false,
          "panel": "shared"
        }
      },
      {
        "label": "Backend Dev",
        "detail": "Start the FastAPI backend development server",
        "type": "shell",
        "command": "make",
        "args": ["dev-backend"],
        "options": {
          "cwd": "${workspaceFolder}"
        },
        "group": "build",
        "isBackground": true,
        "presentation": {
          "echo": true,
          "reveal": "always",
          "focus": false,
          "panel": "dedicated"
        },
        "problemMatcher": {
          "pattern": {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^.*Uvicorn running on.*$",
            "endsPattern": "^.*Application startup complete.*$"
          }
        }
      },
      {
        "label": "Frontend Dev",
        "detail": "Start the Next.js frontend development server",
        "type": "shell",
        "command": "make",
        "args": ["dev-frontend"],
        "options": {
          "cwd": "${workspaceFolder}"
        },
        "group": "build",
        "isBackground": true,
        "presentation": {
          "echo": true,
          "reveal": "always",
          "focus": false,
          "panel": "dedicated"
        },
        "problemMatcher": {
          "pattern": {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^.*ready started server.*$",
            "endsPattern": "^.*Compiled successfully.*$"
          }
        }
      }
    ]
  },
  "extensions": {
    "recommendations": [
      "ms-python.python",
      "ms-python.vscode-pylance",
      "charliermarsh.ruff",
      "dbaeumer.vscode-eslint",
      "esbenp.prettier-vscode",
      "bradlc.vscode-tailwindcss",
      "ms-vscode.vscode-typescript-next",
      "ms-azuretools.vscode-docker",
      "eamodio.gitlens",
      "github.vscode-pull-request-github",
      "tamasfe.even-better-toml",
      "redhat.vscode-yaml",
      "ms-vscode-remote.remote-containers"
    ]
  }
}
